CREATE DATABASE IF NOT EXISTS {{ mysql_app_db }};
CREATE USER IF NOT EXISTS '{{ mysql_app_user }}'@'{{ mysql_app_host }}' IDENTIFIED BY '{{ mysql_app_password }}';
GRANT ALL PRIVILEGES ON {{ mysql_app_db }}.* TO '{{ mysql_app_user }}'@'{{ mysql_app_host }}';
FLUSH PRIVILEGES;

USE {{ mysql_app_db }};

CREATE TABLE IF NOT EXISTS notes (
  id INT AUTO_INCREMENT PRIMARY KEY,
  title VARCHAR(120) NOT NULL,
  body TEXT NOT NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

